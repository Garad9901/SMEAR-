# =============================================================================
# AgroSense AI — Environment Variables
# Copy this file to .env and fill in your actual values
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME="AgroSense AI"
APP_ENV=development           # development | staging | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# Database (PostgreSQL + PostGIS)
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agrosense
POSTGRES_USER=agrosense_user
POSTGRES_PASSWORD=agrosense_password
DATABASE_URL=postgresql+asyncpg://agrosense_user:agrosense_password@localhost:5432/agrosense

# ---------------------------------------------------------------------------
# Redis (Caching + Celery broker)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------------------------------------------------------------------------
# MLflow
# ---------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=agrosense_production
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
MLFLOW_ARTIFACT_STORE=s3://mlflow-artifacts

# ---------------------------------------------------------------------------
# AWS (S3, EC2, SES)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_DEFAULT_REGION=ap-south-1
AWS_S3_BUCKET=agrosense-data
AWS_S3_MODEL_BUCKET=agrosense-models

# ---------------------------------------------------------------------------
# Twilio SMS Alerts
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_ALERT_NUMBER=+91XXXXXXXXXX

# ---------------------------------------------------------------------------
# Firebase (Push Notifications)
# ---------------------------------------------------------------------------
FIREBASE_PROJECT_ID=agrosense-ai
FIREBASE_CREDENTIALS_PATH=./infra/firebase-service-account.json

# ---------------------------------------------------------------------------
# Razorpay (Subscription Billing)
# ---------------------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ---------------------------------------------------------------------------
# External Data APIs
# ---------------------------------------------------------------------------
IMD_API_KEY=your-imd-api-key
NASA_POWER_API_URL=https://power.larc.nasa.gov/api/temporal/daily/point
OPENCITY_API_KEY=your-opencity-api-key

# ---------------------------------------------------------------------------
# Airflow
# ---------------------------------------------------------------------------
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://agrosense_user:agrosense_password@postgres:5432/airflow
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-base64-encoded
AIRFLOW__WEBSERVER__SECRET_KEY=your-airflow-webserver-secret

# ---------------------------------------------------------------------------
# MinIO (Local S3-compatible object store for dev)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://localhost:9000

# ---------------------------------------------------------------------------
# pgAdmin
# ---------------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@agrosense.ai
PGADMIN_DEFAULT_PASSWORD=admin123
